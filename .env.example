# Copy to .env.local (gitignored) and fill in your token.
#
# GitHub Personal Access Token, used to authenticate to GitHub's remote MCP
# server (https://api.githubcopilot.com/mcp/). This is the ONLY secret
# Switchboard needs. Interpolated into the Authorization header defined in
# mcp/github.json at request time.
#
# Scopes: public_repo + read:user (public repos) or repo + read:user (private).
GITHUB_PAT=ghp_your_token_here
